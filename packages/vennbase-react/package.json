{
  "name": "@vennbase/react",
  "version": "0.1.12",
  "description": "React hooks for Vennbase — a multi-user database for apps that have no backend.",
  "license": "Apache-2.0",
  "keywords": ["database", "puter", "backend-free", "collaborative", "realtime", "react", "hooks"],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexdavies74/vennbase.git",
    "directory": "packages/vennbase-react"
  },
  "homepage": "https://vennbase.dev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "smoke:node-esm": "node ../../scripts/run-node-esm-smoke.mjs .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run smoke:node-esm",
    "test": "vitest run"
  },
  "dependencies": {
    "@heyputer/puter.js": "^2.2.11",
    "@vennbase/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}

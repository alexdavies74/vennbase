{
  "name": "@putbase/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "generate:worker-runtime": "node ./scripts/generate-worker-runtime.mjs",
    "prebuild": "pnpm run clean && pnpm run generate:worker-runtime",
    "build": "tsc -p tsconfig.json",
    "predev": "pnpm run generate:worker-runtime",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "pretypecheck": "pnpm run generate:worker-runtime",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prelint": "pnpm run generate:worker-runtime",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm run generate:worker-runtime",
    "test": "vitest run"
  },
  "dependencies": {
    "@heyputer/puter.js": "^2.2.11"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}

{
  "name": "@covedb/react",
  "version": "0.1.5",
  "description": "React hooks for CoveDB — a multi-user database for apps that have no backend.",
  "keywords": ["database", "puter", "backend-free", "collaborative", "realtime", "react", "hooks"],
  "repository": {
    "type": "git",
    "url": "https://github.com/alexdavies74/covedb.git",
    "directory": "packages/covedb-react"
  },
  "homepage": "https://github.com/alexdavies74/covedb/tree/main/packages/covedb-react#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@heyputer/puter.js": "^2.2.11",
    "@covedb/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "jsdom": "^26.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
